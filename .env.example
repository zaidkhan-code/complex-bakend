DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRE=30d
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PORT=8080
NODE_ENV=production
TIMEZONE_API_URL=
BASE_PRICE_PER_DAY=0
VITE_API_URL=
FRONTEND_URL=https://your-frontend-domain.example
CORS_ORIGINS=https://your-frontend-domain.example,https://www.your-frontend-domain.example

# Cloud Run defaults in this project:
# Cron/jobs are disabled unless you explicitly turn them on.
ENABLE_CRON_JOBS=false
ENABLE_JOB_WORKERS=false

# Support messages (footer form)
# Messages are stored in the admin panel; the system sends only an auto-reply to the sender.

# Resend (used for auto-reply email)
# 1) Verify your sending domain in Resend
# 2) Set a verified sender address
RESEND_API_KEY=
RESEND_FROM="Complisk <noreply@complisk.com>"
